{
  "name": "opencode-sandbox",
  "version": "0.2.0",
  "description": "Create isolated Git worktree sandboxes that reuse local development dependencies.",
  "type": "module",
  "packageManager": "pnpm@11.7.0",
  "bin": {
    "opencode-sandbox": "./dist/cli.js",
    "ocs": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/cli.ts",
    "test": "pnpm run build && vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "smoke": "pnpm run build && ./scripts/manual-smoke.sh",
    "prepare": "pnpm run build"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "git-worktree",
    "sandbox",
    "opencode",
    "cli"
  ],
  "license": "MIT",
  "dependencies": {
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "execa": "^9.5.2",
    "proper-lockfile": "^4.1.2"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/proper-lockfile": "^4.1.4",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
