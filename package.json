{
  "name": "@yashkumar/wtx",
  "version": "0.2.1",
  "description": "Create isolated Git worktree sandboxes with instantaneous dependency linking (`reflink`) for feature work and AI/LLM agents.",
  "type": "module",
  "packageManager": "pnpm@11.7.0",
  "bin": {
    "wtx": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "AGENTS.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/cli.ts",
    "test": "tsc -p tsconfig.json && vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "smoke": "tsc -p tsconfig.json && ./scripts/manual-smoke.sh",
    "prepare": "tsc -p tsconfig.json",
    "prepublishOnly": "npm test && npm run build",
    "preversion": "npm test && npm run build",
    "postversion": "git push && git push --tags && npm publish --access public",
    "release": "npm version patch",
    "release:patch": "npm version patch",
    "release:minor": "npm version minor",
    "release:major": "npm version major"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "git-worktree",
    "sandbox",
    "wtx",
    "ai-agents",
    "cli"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/iamyamar/wtx.git"
  },
  "bugs": {
    "url": "https://github.com/iamyamar/wtx/issues"
  },
  "homepage": "https://github.com/iamyamar/wtx#readme",
  "dependencies": {
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "execa": "^9.5.2",
    "proper-lockfile": "^4.1.2"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/proper-lockfile": "^4.1.4",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
